<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SpurGear Pro | Engineering Simulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* GLASSMORPHISM UI */
        body {
            background-color: #020617;
            color: #f1f5f9;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* CUSTOM INPUTS */
        input[type="range"] {
            -webkit-appearance: none;
            background: rgba(255, 255, 255, 0.1);
            height: 4px;
            border-radius: 2px;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px;
            height: 16px;
            background: #60a5fa;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(96, 165, 250, 0.5);
        }

        #outputLog::-webkit-scrollbar {
            width: 4px;
        }

        #outputLog::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }

        .weaker-badge {
            padding: 2px 6px;
            background: #ef4444;
            color: white;
            border-radius: 4px;
            font-size: 9px;
            margin-left: 5px;
            font-weight: bold;
        }

        .grid-bg {
            position: fixed;
            inset: 0;
            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
            background-size: 40px 40px;
            z-index: -1;
        }
    </style>
</head>
<body>
    <div class="grid-bg"></div>
    <div class="fixed inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-blue-900/20 via-slate-950 to-slate-950 -z-10"></div>

    <nav class="border-b border-white/10 backdrop-blur-md sticky top-0 z-50 px-8 py-4 flex justify-between items-center">
        <h1 class="text-2xl font-bold tracking-tighter bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">
            SPURGEAR PRO <span class="text-xs font-mono text-slate-500 font-normal ml-2">v4.0 (DATA HANDBOOK)</span>
        </h1>
        <div class="flex gap-4 text-sm font-medium">
            <span class="text-emerald-400">● Design Active</span>
            <span class="text-slate-400">Lewis-Buckingham Engine</span>
        </div>
    </nav>

    <main class="p-6 grid grid-cols-12 gap-6 max-w-[1600px] mx-auto">
        <section class="col-span-12 lg:col-span-3 glass p-6 rounded-2xl">
            <h2 class="text-lg font-semibold mb-4 border-b border-white/5 pb-2">Input Parameters</h2>
            
            <div class="space-y-6">
                <div>
                    <label class="block text-xs uppercase tracking-wider text-slate-400 mb-2">Power (kW)</label>
                    <input type="range" id="power" min="1" max="100" value="15" class="w-full accent-blue-500">
                    <div class="flex justify-between text-xs mt-1"><span id="powerVal" class="text-blue-400 font-bold">15</span><span>kW</span></div>
                </div>

                <div>
                    <label class="block text-xs uppercase tracking-wider text-slate-400 mb-2">Pinion Speed (RPM)</label>
                    <input type="range" id="rpm" min="100" max="5000" value="1440" class="w-full accent-blue-500">
                    <div class="flex justify-between text-xs mt-1"><span id="rpmVal" class="text-blue-400 font-bold">1440</span><span>RPM</span></div>
                </div>

                <div>
                    <label class="block text-xs uppercase tracking-wider text-slate-400 mb-2">Pinion Material Selection</label>
                    <select id="material" class="w-full bg-slate-900 border border-white/10 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 ring-blue-500 text-white">
                        <option value="cast_iron">Cast Iron (Grade 20) - σ₀: 60 MPa</option>
                        <option value="steel_c45" selected>Steel C45 (Quenched) - σ₀: 140 MPa</option>
                        <option value="alloy_steel">Alloy Steel (20MnCr5) - σ₀: 250 MPa</option>
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-slate-400">Teeth (Pinion)</label>
                        <input type="number" id="z1" value="18" class="w-full bg-slate-900 border border-white/10 rounded p-1 text-sm text-white">
                    </div>
                    <div>
                        <label class="block text-xs text-slate-400">Gear Ratio (i)</label>
                        <input type="number" id="ratio" value="3" step="0.1" class="w-full bg-slate-900 border border-white/10 rounded p-1 text-sm text-white">
                    </div>
                </div>

                <button id="calculateBtn" class="w-full py-3 bg-blue-600 hover:bg-blue-500 transition-all rounded-xl font-bold shadow-lg shadow-blue-900/20 text-white">
                    CALCULATE DESIGN
                </button>
            </div>
        </section>

        <section class="col-span-12 lg:col-span-6 space-y-6">
            <div class="glass h-[500px] rounded-2xl relative overflow-hidden group">
                <div id="canvas-container" class="w-full h-full"></div>
                <div class="absolute top-4 left-4 flex gap-2">
                    <span class="px-3 py-1 bg-blue-500/20 text-blue-400 rounded-full text-[10px] border border-blue-500/30 uppercase tracking-widest font-bold">3D CAD Preview</span>
                </div>
            </div>

            <div class="grid grid-cols-3 gap-4">
                <div class="glass p-4 rounded-xl border border-white/5 text-center">
                    <p class="text-[10px] text-slate-500 uppercase">Selected Module</p>
                    <p id="resModule" class="text-2xl font-mono text-blue-400 font-bold">--</p>
                </div>
                <div class="glass p-4 rounded-xl border border-white/5 text-center">
                    <p class="text-[10px] text-slate-500 uppercase">Factor of Safety</p>
                    <p id="resFOS" class="text-2xl font-mono text-emerald-400 font-bold">--</p>
                </div>
                <div class="glass p-4 rounded-xl border border-white/5 text-center">
                    <p class="text-[10px] text-slate-500 uppercase">Weaker Member</p>
                    <p id="resWeaker" class="text-lg font-mono text-slate-300 font-bold">--</p>
                </div>
            </div>
        </section>

        <section class="col-span-12 lg:col-span-3 space-y-6">
            <div class="glass p-6 rounded-2xl h-[380px] flex flex-col">
                <h2 class="text-sm font-bold mb-4 flex items-center gap-2">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                    ENGINEERING LOG
                </h2>
                <div id="outputLog" class="flex-1 space-y-3 text-[11px] font-mono text-slate-400 overflow-y-auto pr-2">
                    </div>
            </div>

            <div class="glass p-4 rounded-2xl">
                <h3 class="text-xs font-bold text-slate-500 mb-4 uppercase text-center">Load Comparisons (Newton)</h3>
                <div class="h-[200px]">
                    <canvas id="loadChart"></canvas>
                </div>
            </div>
        </section>
    </main>

    <script>
        /**
         * SPUR GEAR DESIGN SYSTEM ENGINE
         */

        const MATERIALS = {
            cast_iron: { sigma0: 60, bhn: 200, E: 1.1e5 },
            steel_c45: { sigma0: 140, bhn: 250, E: 2.1e5 },
            alloy_steel: { sigma0: 250, bhn: 400, E: 2.1e5 }
        };

        class SpurGearApp {
            constructor() {
                this.initThreeJS();
                this.initChart();
                this.setupListeners();
                this.calculate(); // Initial run
            }

            setupListeners() {
                const inputs = ['power', 'rpm', 'z1', 'ratio', 'material'];
                inputs.forEach(id => {
                    document.getElementById(id).addEventListener('input', (e) => {
                        const valDisplay = document.getElementById(`${id}Val`);
                        if (valDisplay) valDisplay.innerText = e.target.value;
                        this.calculate();
                    });
                });
                document.getElementById('calculateBtn').addEventListener('click', () => this.calculate());
            }

            initThreeJS() {
                const container = document.getElementById('canvas-container');
                this.scene = new THREE.Scene();
                this.camera = new THREE.PerspectiveCamera(45, container.offsetWidth / container.offsetHeight, 0.1, 1000);
                this.renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
                this.renderer.setSize(container.offsetWidth, container.offsetHeight);
                container.appendChild(this.renderer.domElement);

                // Lighting
                const light1 = new THREE.DirectionalLight(0xffffff, 1);
                light1.position.set(5, 5, 5);
                this.scene.add(light1, new THREE.AmbientLight(0x404040, 2));

                this.gearGroup = new THREE.Group();
                this.scene.add(this.gearGroup);
                this.camera.position.z = 30;

                const animate = () => {
                    requestAnimationFrame(animate);
                    const i = parseFloat(document.getElementById('ratio').value);
                    if(this.gearGroup.children[0]) this.gearGroup.children[0].rotation.z += 0.01;
                    if(this.gearGroup.children[1]) this.gearGroup.children[1].rotation.z -= 0.01 / i;
                    this.renderer.render(this.scene, this.camera);
                };
                animate();
            }

            initChart() {
                const ctx = document.getElementById('loadChart').getContext('2d');
                this.chart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ['Static', 'Dynamic', 'Wear'],
                        datasets: [{
                            label: 'Force (N)',
                            data: [0, 0, 0],
                            backgroundColor: ['#3b82f6', '#f59e0b', '#10b981'],
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { grid: { color: 'rgba(255,255,255,0.1)' }, ticks: { color: '#64748b', font: { size: 10 } } },
                            x: { ticks: { color: '#64748b', font: { size: 10 } } }
                        }
                    }
                });
            }

            log(msg, color = "text-slate-400") {
                const logBox = document.getElementById('outputLog');
                const div = document.createElement('div');
                div.className = `${color} border-l-2 border-current pl-2 py-1 bg-white/5`;
                div.innerHTML = `> ${msg}`;
                logBox.prepend(div);
            }

            calculate() {
                document.getElementById('outputLog').innerHTML = '';
                const P = parseFloat(document.getElementById('power').value) * 1000;
                const N1 = parseFloat(document.getElementById('rpm').value);
                const Z1 = parseInt(document.getElementById('z1').value);
                const i = parseFloat(document.getElementById('ratio').value);
                const Z2 = Math.round(Z1 * i);
                const mat = MATERIALS[document.getElementById('material').value];

                // 1. WEAKER MEMBER DETERMINATION (LEWIS FORM FACTOR)
                const Y1 = Math.PI * (0.154 - (0.912 / Z1)); 
                const Y2 = Math.PI * (0.154 - (0.912 / Z2));
                
                const sigma_y1 = mat.sigma0 * Y1;
                const sigma_y2 = mat.sigma0 * Y2; // Assuming same material for both
                
                const pinionIsWeaker = sigma_y1 <= sigma_y2;
                const weakerMember = pinionIsWeaker ? "Pinion" : "Gear";
                const activeY = pinionIsWeaker ? Y1 : Y2;
                
                document.getElementById('resWeaker').innerText = weakerMember.toUpperCase();
                this.log(`Pinion σY: ${sigma_y1.toFixed(2)} | Gear σY: ${sigma_y2.toFixed(2)}`);
                this.log(`${weakerMember} identified as weaker member.`);

                // 2. MODULE CALCULATION (Trial)
                const torque = (9.55e6 * (P / 1000)) / N1;
                let m = Math.ceil(Math.pow((2 * torque) / (mat.sigma0 * 10 * activeY * Z1), 1/3));
                if (m < 1) m = 1;
                
                // 3. DIMENSIONS
                const d1 = m * Z1;
                const d2 = m * Z2;
                const b = 10 * m; // Face width
                const v = (Math.PI * d1 * N1) / 60000; // Velocity m/s
                const Cv = 3 / (3 + v); // Velocity Factor

                // 4. LOADS
                const Wt = P / v; // Tangential Load
                const Ws = mat.sigma0 * b * m * activeY * Cv; // Beam Strength (Static)
                
                // Dynamic Load (Buckingham Approx)
                const error = 0.02; // Precision gear error mm
                const C = 11860 * error; 
                const Wd = Wt + (21 * v * (b * C + Wt)) / (21 * v + Math.sqrt(b * C + Wt));

                // Wear Load
                const Q = (2 * i) / (i + 1);
                const K = (mat.bhn * mat.bhn * 1.4) / 1e6;
                const Ww = d1 * b * Q * K;

                // 5. UPDATES
                document.getElementById('resModule').innerText = m + " mm";
                const fos = (Ws / Wt).toFixed(2);
                document.getElementById('resFOS').innerText = fos;

                this.chart.data.datasets[0].data = [Ws.toFixed(0), Wd.toFixed(0), Ww.toFixed(0)];
                this.chart.update();

                this.log(`W_static (Beam): ${Ws.toFixed(0)} N`, "text-blue-400");
                this.log(`W_dynamic (Impact): ${Wd.toFixed(0)} N`, "text-amber-400");
                this.log(`W_wear (Surface): ${Ww.toFixed(0)} N`, "text-emerald-400");

                if (Ws < Wd) this.log("CRITICAL: Beam Strength < Dynamic Load!", "text-red-500 font-bold");
                if (Ww < Wd) this.log("WARNING: Surface Wear failure possible.", "text-red-400");
                if (fos > 1.5 && Ww > Wd) this.log("Design highly stable and verified.", "text-emerald-500 font-bold");

                this.update3D(d1, d2);
            }

            update3D(d1, d2) {
                this.gearGroup.clear();
                const mat = new THREE.MeshStandardMaterial({ 
                    color: 0x3b82f6, 
                    metalness: 0.7, 
                    roughness: 0.2,
                    wireframe: true 
                });

                const pGeo = new THREE.CylinderGeometry(d1/15, d1/15, 3, 32);
                const gGeo = new THREE.CylinderGeometry(d2/15, d2/15, 3, 32);

                const pMesh = new THREE.Mesh(pGeo, mat);
                const gMesh = new THREE.Mesh(gGeo, mat);

                pMesh.rotation.x = Math.PI / 2;
                gMesh.rotation.x = Math.PI / 2;
                gMesh.position.x = (d1 + d2) / 30;

                this.gearGroup.add(pMesh, gMesh);
                this.gearGroup.position.x = -(d1 + d2) / 60;
            }
        }

        // Boot
        window.onload = () => new SpurGearApp();
    </script>
</body>
</html>
